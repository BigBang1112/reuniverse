@using Microsoft.AspNetCore.Components.Forms
@using Reuniverse.Razor.TypeValueComponents
@using TmEssentials

@inherits TypeValueComponentBase<TimeSingle?>

@if (Value.HasValue)
{
    <input @bind="Value" readonly="@IsReadOnly" @oninput="e => tempValue = e.Value?.ToString()" placeholder="@Placeholder" minlength="8" style="min-width: 8ch;width:@(tempValue?.Length ?? Value?.ToString().Length ?? 0)ch" />
}
else
{
    <span class="box-value clickable" @onclick="() => Value = default(TimeSingle)">@None</span>
}

@if (Exception is not null)
{
    <div style="color: var(--color-red);">@Exception.Message</div>
}

@code {
    private string? tempValue;
}