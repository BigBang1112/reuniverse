@page "/components"
@layout MainLayout

<PageTitle>Components - Reuniverse</PageTitle>

<h1>Components</h1>

<div class="components">
    <div>
        <h2>&lt;ReuCheckbox&gt;</h2>
    </div>
    <div>
        <ReuCheckbox>Should do this?</ReuCheckbox>
        <ReuCheckbox disabled>Should do this?</ReuCheckbox>
    </div>
    <div>
        <h2>&lt;ReuRadio&gt;</h2>
    </div>
    <div>
        <ReuRadio Name="Rad">Option 1</ReuRadio>
        <ReuRadio Name="Rad">Option 2</ReuRadio>
        <ReuRadio Name="Rad" disabled>Option 3</ReuRadio>
        <ReuRadio Name="Rad">Option 4</ReuRadio>
    </div>
    <div>
        <h2>&lt;ReuButton&gt;</h2>
    </div>
    <div style="display: flex; flex-wrap: wrap; gap: 0.5rem;">
        <ReuButton Tooltip="This button is enabled">Enabled button</ReuButton>
        <ReuButton Enable="false">Disabled button</ReuButton>
        <ReuButton Variant="ReuButtonVariant.Blue" Enable="false">Disabled blue button</ReuButton>
        <ReuButton Variant="ReuButtonVariant.Red">Red button</ReuButton>

        <ReuButton Href="https://gbx.tools" Variant="ReuButtonVariant.Yellow">Enabled link</ReuButton>
        <ReuButton Href="https://gbx.tools" Variant="ReuButtonVariant.Yellow" Enable="false">Disabled link</ReuButton>
    </div>
    <div>
        <h2>&lt;ReuExpansionPanels&gt;</h2>
    </div>
    <div>
        <ReuExpansionPanels>
            <ReuExpansionPanel>
                <TitleContent>
                    Expansion Panel 1
                </TitleContent>
                <ChildContent>
                    This is the content of Expansion Panel 1.
                </ChildContent>
            </ReuExpansionPanel>
            <ReuExpansionPanel>
                <TitleContent>
                    Expansion Panel 2
                </TitleContent>
                <ChildContent>
                    This is the content of Expansion Panel 2.
                </ChildContent>
            </ReuExpansionPanel>
            <ReuExpansionPanel>
                <TitleContent>
                    Expansion Panel 3
                </TitleContent>
                <ChildContent>
                    This is the content of Expansion Panel 3.
                </ChildContent>
            </ReuExpansionPanel>
        </ReuExpansionPanels>
    </div>
    <div>
        <h2>&lt;ReuTabs&gt;</h2>
    </div>
    <div>
        <ReuTabs>
            <ReuTab>
                <TitleContent>
                    Tab 1
                </TitleContent>
                <ChildContent>
                    This is the content of Tab 1.
                </ChildContent>
            </ReuTab>
            <ReuTab>
                <TitleContent>
                    Tab 2
                </TitleContent>
                <ChildContent>
                    This is the content of Tab 2.
                </ChildContent>
            </ReuTab>
            <ReuTab>
                <TitleContent>
                    Tab 3
                </TitleContent>
                <ChildContent>
                    This is the content of Tab 3.
                </ChildContent>
            </ReuTab>
        </ReuTabs>
    </div>
    <div>
        <h2>&lt;ReuList&gt;</h2>
    </div>
    <div>
        <ReuList Panel="true" Wrap="true">
            <ReuListItem><img alt="TMSX" width="48" height="48" /></ReuListItem>
            <ReuListItem><img alt="TMNESWC" width="48" height="48" /></ReuListItem>
            <ReuListItem><img alt="TMUF" width="48" height="48" /></ReuListItem>
            <ReuListItem><img alt="TMT" width="48" height="48" /></ReuListItem>
            <ReuListItem><img alt="MP4" width="48" height="48" /></ReuListItem>
            <ReuListItem><img alt="TM2020" width="48" height="48" /></ReuListItem>
        </ReuList>
        <ReuList Panel="true" Vertical="true" Grow="false" style="height: 50px">
            <ReuListItem>A</ReuListItem>
            <ReuListItem>B</ReuListItem>
            <ReuListItem>C</ReuListItem>
            <ReuListItem>D</ReuListItem>
            <ReuListItem>E</ReuListItem>
            <ReuListItem>F</ReuListItem>
        </ReuList>
    </div>
    <div>
        <h2>&lt;ReuUploadButton&gt;</h2>
    </div>
    <div>
        <ReuUploadButton>Open files...</ReuUploadButton>
    </div>
    <div>
        <h2>&lt;ReuUploadArea&gt;</h2>
    </div>
    <div>
        <ReuUploadArea></ReuUploadArea>
    </div>
    <div>
        <h2>&lt;ReuLoader&gt;</h2>
    </div>
    <div>
        <ReuLoader></ReuLoader>
    </div>
    <div>
        <h2>&lt;ReuFriendlyType&gt;</h2>
    </div>
    <div>
        <ReuFriendlyType Type="typeof(Dictionary<string, List<int>>)"></ReuFriendlyType>
    </div>
    <div>
        <h2>&lt;ReuMenuBar&gt;</h2>
    </div>
    <div>
        <ReuMenuBar Items="items"></ReuMenuBar>
    </div>
    <div>
        <h2>&lt;ReuFileBrowser&gt;</h2>
    </div>
    <div>
        <ReuFileBrowser Root="sampleRoot" OnFileOpen="f => lastOpened = f.Name" style="height: 340px"></ReuFileBrowser>
        @if (lastOpened is not null)
        {
            <p class="file-opened-hint">Opened: <strong>@lastOpened</strong></p>
        }
    </div>
    <div>
        <h2>&lt;ReuLogs&gt;</h2>
        <div style="display: flex; flex-wrap: wrap; gap: 0.5rem;">
            <ReuButton OnClick="LogSamples">Log all levels</ReuButton>
            <ReuButton OnClick="LogParameterized">Log parameterized</ReuButton>
            <ReuButton Variant="ReuButtonVariant.Red" OnClick="LogException">Log exception</ReuButton>
            <ReuButton OnClick="LogScoped">Log with scopes</ReuButton>
            <ReuButton OnClick="() => logProvider.Clear()">Clear</ReuButton>
        </div>
    </div>
    <div>
        <ReuLogs Provider="logProvider"
                 OnEntryClick="e => clickedException = e.Exception?.ToString()"
                 OnParameterClick='p => clickedParameter = $"{p.Name} = {p.Value}"'
                 style="height: 340px"></ReuLogs>
        @if (clickedException is not null)
        {
            <p class="file-opened-hint">Clicked exception:</p>
            <pre style="overflow: auto; max-height: 160px;">@clickedException</pre>
        }
        @if (clickedParameter is not null)
        {
            <p class="file-opened-hint">Clicked parameter: <strong>@clickedParameter</strong></p>
        }
    </div>
    <div>
        <h2>&lt;ReuObjectTree&gt;</h2>
        <ReuCheckbox IsCheckedChanged="OnTypesChanged" IsChecked="@showTypes">Types</ReuCheckbox>
    </div>
    <div style="overflow: auto">
        <ReuObjectTree Value="obj" HideType="!showTypes" IsExpandedByDefault="true"></ReuObjectTree>
    </div>
</div>

