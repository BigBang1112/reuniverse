    // ── ReuFileBrowser sample data ─────────────────────────────────────────────

    private string? lastOpened;

    private IReuFolder sampleRoot = new SampleFolder("My Documents",
    [
        new SampleFolder("Projects",
        [
            new SampleFolder("Reuniverse",
            [
                new SampleFile("README.md",          4_096,   DateTimeOffset.Now.AddDays(-30)),
                new SampleFile("Reuniverse.slnx",    1_200,   DateTimeOffset.Now.AddDays(-5)),
            ]),
            new SampleFolder("GbxTools",
            [
                new SampleFile("notes.txt",          512,     DateTimeOffset.Now.AddDays(-90)),
            ]),
        ]),
        new SampleFolder("Pictures",
        [
            new SampleFile("profile.png",           204_800, DateTimeOffset.Now.AddDays(-1)),
            new SampleFile("screenshot.png",        81_920,  DateTimeOffset.Now.AddDays(-3)),
        ]),
        new SampleFile("budget.xlsx",               25_600,  DateTimeOffset.Now.AddDays(-7)),
        new SampleFile("notes.txt",                 1_024,   DateTimeOffset.Now.AddDays(-14)),
    ]);

    private sealed record SampleFile(string Name, long Size, DateTimeOffset LastModified) : IReuFile
    {
        long? IReuFile.Size => Size;
        DateTimeOffset? IReuFile.LastModified => LastModified;
    }

    private sealed record SampleFolder(string Name, IEnumerable<IReuEntry> Entries) : IReuFolder;

    // ── ReuLogs sample data ────────────────────────────────────────────────────

    private readonly ReuLoggerProvider logProvider = new();
    private ILogger Logger => logProvider.CreateLogger("Overview.Components");
    private string? clickedException;
    private string? clickedParameter;

    private void LogSamples()
    {
        Logger.LogTrace("Entering render loop");
        Logger.LogDebug("Cache miss, fetching from source");
        Logger.LogInformation("Application started successfully");
        Logger.LogWarning("Disk space is running low");
        Logger.LogError("Failed to connect to the database");
        Logger.LogCritical("Unrecoverable state, shutting down");
    }

    private void LogParameterized()
    {
        Logger.LogInformation("User {UserId} logged in from {IpAddress}", Guid.NewGuid(), "192.168.1.42");
        Logger.LogInformation("Processed {Count} items in {ElapsedMs} ms", 128, 37.5);
        Logger.LogWarning("Rate limit reached for {Endpoint}: {Current}/{Limit}", "/api/upload", 100, 100);
    }

    private void LogException()
    {
        try
        {
            throw new InvalidOperationException("Something went wrong while processing the request.");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unhandled error in {Operation}", "ProcessRequest");
        }
    }

    private void LogScoped()
    {
        using (Logger.BeginScope("Base48x48Screen155Day.Decoration.Gbx"))
        {
            Logger.LogDebug("Opening file");
            using (Logger.BeginScope("GBX.NET"))
            {
                Logger.LogInformation("Parsing header");
                using (Logger.BeginScope("CGameCtnDecoration (main)"))
                {
                    Logger.LogInformation("Reading chunk 0x03036000");
                    using (Logger.BeginScope("Refe"))
                    {
                        Logger.LogInformation("Resolving reference");
                        Logger.LogWarning("Reference target not found");
                    }
                    Logger.LogInformation("Chunk read successfully");
                }
                Logger.LogInformation("Parsing complete");
            }
        }
    }

    // ─────────────────────────────────────────────────────────────────────────

    private bool showTypes = true;

    private void OnTypesChanged(bool isChecked)
    {
        showTypes = isChecked;
    }

    public enum UserStatus
    {
        Active,
        Suspended,
        Deleted
    }

    public class Address
    {
        public required string Street { get; set; }
        public required string City { get; set; }
        public required string Country { get; set; }
        public required GeoLocation? Location { get; set; }
    }

    public class GeoLocation
    {
        public double Latitude { get; set; }
        public double Longitude { get; set; }
    }

    public class UserPreferences
    {
        public bool ReceiveNewsletter { get; set; }
        public required Dictionary<string, string> CustomSettings { get; set; }
    }

    public class Order
    {
        public Guid OrderId { get; set; }
        public DateTime CreatedAt { get; set; }
        public required List<OrderItem> Items { get; set; }
        public decimal TotalAmount { get; set; }
        public required Dictionary<string, object?> Metadata { get; set; }
    }

    public class OrderItem
    {
        public required string Sku { get; set; }
        public required string Name { get; set; }
        public int Quantity { get; set; }
        public decimal UnitPrice { get; set; }
        public required List<string> Tags { get; set; }
    }

    public class User
    {
        public Guid Id { get; set; }
        public required string Username { get; set; }
        public UserStatus Status { get; set; }
        public DateTime? LastLogin { get; set; }

        public required Address PrimaryAddress { get; set; }
        public required List<Address> PreviousAddresses { get; set; }

        public UserPreferences? Preferences { get; set; }
        public required List<Order> Orders { get; set; }

        public required Dictionary<string, object> Extensions { get; set; }
    }
}
