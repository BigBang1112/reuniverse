<div class="reu-tabs @CssClass" @attributes="AdditionalAttributes">
    <CascadingValue Value="this" IsFixed="true">
        <div class="header">
            @foreach (var tab in Tabs)
            {
                <span @onclick="() => SelectTabAsync(tab)">@tab.TitleContent</span>
            }
        </div>
        <div class="content">
            @ChildContent
        </div>
    </CascadingValue>
</div>

@code {
    internal List<ReuTab> Tabs { get; } = new();

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Additional CSS classes to apply to the element.
    /// </summary>
    [Parameter]
    public string? CssClass { get; set; }

    /// <summary>
    /// Index of the tab that should be selected by default.
    /// </summary>
    [Parameter]
    public int DefaultTab { get; set; } = 0;

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? AdditionalAttributes { get; set; }

    internal void Register(ReuTab tab)
    {
        Tabs.Add(tab);
        StateHasChanged();
    }

    internal async Task SelectTabAsync(ReuTab tab)
    {
        foreach (var t in Tabs)
        {
            t.Selected = false;
        }

        tab.Selected = true;
        await InvokeAsync(StateHasChanged);
    }
}