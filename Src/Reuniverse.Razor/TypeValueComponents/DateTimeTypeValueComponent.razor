@using Microsoft.AspNetCore.Components.Forms

@inherits TypeValueComponentBase<DateTime?>

<input @bind="Value" @bind:format="@format" readonly="@IsReadOnly" @oninput="OnInput" minlength="19" style="min-width: 19ch;width:@(tempValue?.Length ?? Value?.ToString(format).Length ?? 0)ch" />
@if (Exception is not null)
{
    <div style="color: var(--color-red);">@Exception.Message</div>
}

@code {
    private static string format = "yyyy-MM-dd HH:mm:ss.FFFFFFF";

    private string? tempValue;

    private async Task OnInput(ChangeEventArgs e)
    {
        tempValue = e.Value?.ToString();
    }
}